<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.rillanai.rillan</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/sh</string>
		<string>-lc</string>
		<string>exec "$HOME/.local/bin/rillan" serve --config "$HOME/.config/rillan/config.yaml"</string>
	</array>

	<key>WorkingDirectory</key>
	<string>__RILLAN_WORKDIR__</string>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<true/>

	<key>StandardOutPath</key>
	<string>$HOME/.local/state/rillan/logs/service.stdout.log</string>

	<key>StandardErrorPath</key>
	<string>$HOME/.local/state/rillan/logs/service.stderr.log</string>
</dict>
</plist>
